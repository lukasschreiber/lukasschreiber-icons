{
    "name": "@lukasschreiber/icons",
    "version": "0.1.0",
    "private": true,
    "type": "module",
    "sideEffects": false,
    "main": "./dist/index.cjs",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js",
            "require": "./dist/index.cjs"
        }
    },
    "files": [
        "dist"
    ],
    "scripts": {
        "generate": "node scripts/generate-icons.mjs",
        "build": "npm run generate && tsup",
        "prepublishOnly": "npm run build"
    },
    "peerDependencies": {
        "react": ">=18"
    },
    "devDependencies": {
        "@svgr/core": "latest",
        "@svgr/plugin-jsx": "latest",
        "@svgr/plugin-svgo": "latest",
        "@types/react": "^19.2.14",
        "prettier": "latest",
        "tsup": "latest",
        "typescript": "latest"
    }
}
