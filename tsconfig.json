{
    "compilerOptions": {
        "target": "ES2020",
        "module": "ESNext",

        "jsx": "react-jsx",

        "moduleResolution": "Bundler",

        "strict": true,
        "skipLibCheck": true,

        "declaration": true,
        "emitDeclarationOnly": false,

        "esModuleInterop": true,
        "allowSyntheticDefaultImports": true
    },
    "include": ["src"]
}
